# --- App ---------------------------------------------------------------
NODE_ENV=development
PORT=5000

# --- Database ------------------------------------------------------------
# MongoDB connection string (Atlas or local).
MONGO_URI=mongodb://localhost:27017/tronschool

# --- CORS ------------------------------------------------------------------
# Comma-separated list of allowed frontend origins.
# Defaults to http://localhost:3000,http://localhost:5173 if left unset.
CLIENT_ORIGINS=http://localhost:5173

# --- Cloudinary (file/image uploads) ----------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- JWT Auth ----------------------------------------------------------
# Use long, random strings in production (e.g. `openssl rand -hex 64`).
ACCESS_TOKEN_SECRET=
# Duration formats accepted: plain seconds ("900"), or <number><unit>
# where unit is one of ms|s|m|h|d|w, e.g. "15m", "7d".
ACCESS_TOKEN_EXPIRES_IN=15m

REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRES_IN=7d

# --- CSRF ----------------------------------------------------------------
# Optional: falls back to ACCESS_TOKEN_SECRET if not set. Set a dedicated
# secret in production.
CSRF_SECRET=
